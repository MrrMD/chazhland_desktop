# Боевые настройки для ПРОДАКШН-СБОРКИ (vite build / electron-builder, в т.ч. в CI).
# Vite в production-режиме грузит этот файл автоматически — он перебивает локальный .env
# (который gitignored и на раннере GitHub отсутствует, из-за чего сборки уходили в MOCK).
# Значения публичные (адреса уже открытого бэкенда), не секреты — поэтому в git.
VITE_API_BASE=https://api.chazhland.ru
VITE_WS_URL=wss://api.chazhland.ru/ws
VITE_MOCK=false
