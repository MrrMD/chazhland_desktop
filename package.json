{
  "name": "chazhland-desktop",
  "private": true,
  "version": "0.0.1",
  "description": "Десктоп-клиент мессенджера chazhland (Windows-first, Electron)",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "icons": "node scripts/gen-icons.mjs",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "ru.chazhland.desktop",
    "productName": "chazhland",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "build/tray*.png",
      "package.json",
      "node_modules/**/*"
    ],
    "asar": true,
    "npmRebuild": false,
    "asarUnpack": [
      "**/*.node",
      "node_modules/node-datachannel/**"
    ],
    "win": {
      "target": [
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "extraResources": [
        {
          "from": "resources/mpv/win32-x64",
          "to": "mpv"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "build/icon.png",
      "identity": null
    }
  },
  "dependencies": {
    "@livekit/krisp-noise-filter": "^0.4.3",
    "@sapphi-red/web-noise-suppressor": "^0.3.5",
    "@stomp/stompjs": "^7.0.0",
    "livekit-client": "^2.5.0",
    "lucide-react": "^1.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "webtorrent": "^3.0.16"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
