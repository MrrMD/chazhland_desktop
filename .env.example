# Скопируй в .env:  cp .env.example .env
#
# Без файла .env приложение по умолчанию стартует в MOCK-режиме (фейковые данные из src/mocks,
# реального бэкенда нет). Чтобы работать с ЖИВЫМ сервером — нужен .env с настройками ниже.

# ===== Боевой режим (живой бэкенд chazhland) — то, что нужно большинству ⇐ дефолт =====
VITE_API_BASE=https://api.chazhland.ru
VITE_WS_URL=wss://api.chazhland.ru/ws
VITE_MOCK=false

# ===== Локальная разработка UI без бэкенда (mock-данные) — раскомментируй вместо блока выше =====
# VITE_API_BASE=http://localhost:8080
# VITE_WS_URL=ws://localhost:8080/ws
# VITE_MOCK=true
